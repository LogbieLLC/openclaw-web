# OpenClaw gateway URL (default: local loopback)
OPENCLAW_URL=http://127.0.0.1:18789/v1/chat/completions

# Gateway bearer token (from openclaw.json gateway.auth.token)
OPENCLAW_TOKEN=your_token_here

# ── Secret injection ──
# Any env var prefixed with SECRET_ can be injected into chat messages
# using the {{VAR_NAME}} syntax. The actual value is sent to the AI;
# the UI displays a 🔒 chip instead of the real value.
#
# Example:
# SECRET_OPENAI_KEY=sk-...
# SECRET_MY_TOKEN=Bearer abc123
#
# Then type in chat: "Here is my key: {{SECRET_OPENAI_KEY}}"
